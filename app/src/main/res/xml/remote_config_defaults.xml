<?xml version="1.0" encoding="utf-8"?>
<defaultsMap>
    <!-- Production API origin. Firebase Console can override this value remotely. -->
    <entry>
        <key>backend_base_url</key>
        <value>https://goalio-backend-sd2p.onrender.com</value>
    </entry>

    <entry>
        <key>privacy_policy_url</key>
        <value>https://goalio.app/privacy</value>
    </entry>

    <entry>
        <key>onesignal_app_id</key>
        <value>4159dbb2-0f8d-4da3-945d-dc590d14f729</value>
    </entry>

    <!-- Profile setup feature switch. -->
    <entry>
        <key>profile_setup_enabled</key>
        <value>true</value>
    </entry>

    <!-- Maximum favorites selectable during profile setup. -->
    <entry>
        <key>profile_teams_limit</key>
        <value>6</value>
    </entry>
    <entry>
        <key>profile_players_limit</key>
        <value>6</value>
    </entry>

    <!-- Competition hub switches. World Cup wins when both are enabled. -->
    <entry>
        <key>world_cup_enabled</key>
        <value>true</value>
    </entry>
    <entry>
        <key>league_screen_enabled</key>
        <value>false</value>
    </entry>
</defaultsMap>
